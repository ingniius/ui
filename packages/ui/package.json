{
  "name": "@iueev/ui",
  "type": "module",
  "version": "0.0.0",
  "author": "@omaucf <omaucf@pm.me>",
  "license": "MIT",
  "homepage": "https://github.com/ingniius/ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ingniius/ui.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/ingniius/ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    "./runtime/*": "./dist/runtime/*",
    "./composables/*": "./dist/runtime/composables/*",
    "./defaults": {
      "types": "./dist/defaults.d.mts",
      "import": "./dist/defaults.mjs"
    },
    ".": {
      "style": "./dist/runtime/index.css",
      "types": "./dist/module.d.mts",
      "import": "./dist/module.mjs"
    },
    "./package.json": "./package.json"
  },
  "module": "./dist/module.mjs",
  "source": "./dist/module.ts",
  "style": "./dist/runtime/index.css",
  "typesVersions": {
    "*": {
      "runtime/*": [
        "./dist/runtime/*"
      ],
      "composables/*": [
        "./dist/runtime/composables/*"
      ],
      "./defaults": [
        "./dist/defaults.d.mts"
      ],
      ".": [
        "./dist/module.d.mts"
      ]
    }
  },
  "imports": {
    "#build/ui.css": "./.nuxt/ui.css"
  },
  "files": [
    "LICENSE.md",
    "README.md",
    "dist",
    "package.json"
  ],
  "scripts": {
    "prepare": "[ ! -d dist ] && run-s dev || true && [ ! -d .nuxt ] && nuxt-module-build prepare || true",
    "dev": "nuxt-module-build build --stub",
    "build": "nuxt-module-build build",
    "lint": "eslint src/**/*.{css,ts,vue} --fix --cache --cache-location .cache/.eslintcache",
    "test": "vitest run",
    "typecheck": "nuxt typecheck --noEmit",
    "clean": "rimraf .cache .data .nuxt .turbo coverage dist node_modules"
  },
  "peerDependencies": {
    "nuxt": ">=3",
    "vue": ">=3",
    "zod": ">=3"
  },
  "peerDependenciesMeta": {
    "nuxt": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "dependencies": {
    "@nuxt/fonts": "^0.11.1",
    "@nuxt/icon": "^1.11.0",
    "@nuxtjs/color-mode": "^3.5.2",
    "@tailwindcss/postcss": "^4.1.3",
    "@tailwindcss/vite": "^4.1.3",
    "@vueuse/core": "^13.0.0",
    "defu": "^6.1.4",
    "es-toolkit": "^1.34.1",
    "reka-ui": "^2.2.0",
    "scule": "^1.3.0",
    "tailwind-variants": "^1.0.0",
    "tailwindcss": "^4.1.3"
  },
  "optionalDependencies": {
    "@nuxt/content": ">=3",
    "@nuxt/image": ">=1"
  },
  "devDependencies": {
    "nuxt": "catalog:",
    "vue": "catalog:",
    "zod": "catalog:"
  }
}
