{
  "name": "@vee-ui/nuxt",
  "version": "0.0.7-rc-2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ingniius/ui.git",
    "directory": "packages/core/nuxt"
  },
  "license": "Apache-2.0",
  "author": "@ingniius <ingniius@pm.me>",
  "contributors": [
    "@omaucf <omaucf@pm.me>"
  ],
  "homepage": "https://github.com/ingniius/ui#readme",
  "bugs": {
    "url": "https://github.com/ingniius/ui/issues"
  },
  "type": "module",
  "main": "./dist/module.cjs",
  "module": "./dist/module.mjs",
  "source": "./dist/module.ts",
  "types": "./dist/module.d.ts",
  "exports": {
    ".": {
      "types": "./dist/module.d.ts",
      "require": "./dist/module.cjs",
      "import": "./dist/module.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "package.json",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "[ ! -d dist ] && nuxt-module-build build --stub || true",
    "start": "nuxt-module-build build --stub",
    "build": "nuxt-module-build build",
    "check": "vue-tsc --noEmit",
    "format": "prettier src/**/*.{ts,vue} --write --cache --cache-location node_modules/.cache/.prettiercache",
    "lint": "eslint src/**/*.{ts,vue} --fix --cache --cache-location node_modules/.cache/.eslintcache",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf coverage dist .nuxt .turbo node_modules",
    "postinstall": "nuxt-module-build prepare"
  },
  "dependencies": {
    "@iconify-json/heroicons": "^1.2.1",
    "@iconify-json/simple-icons": "^1.2.11",
    "@nuxt/content": "^2.13.4",
    "@nuxt/image": "^1.8.1",
    "@nuxt/ui": "next",
    "@nuxtjs/mdc": "^0.9.2",
    "@vee-ui/system": "workspace:*",
    "@vee-ui/util": "workspace:*",
    "@vueuse/core": "^11.2.0",
    "@vueuse/nuxt": "^11.2.0",
    "defu": "^6.1.4",
    "radix-vue": "^1.9.8"
  },
  "peerDependencies": {
    "nuxt": ">=3",
    "vue": ">=3"
  },
  "devDependencies": {
    "nuxt": "^3.14.159",
    "vue": "^3.5.12"
  },
  "prettier": "@vee-ui/prettier/base",
  "typesVersions": {
    "*": {
      "*": [
        "src/*"
      ]
    }
  }
}
