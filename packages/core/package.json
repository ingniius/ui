{
  "name": "@veehance/core",
  "version": "0.0.0",
  "type": "module",
  "author": "@ingniius <ingniius@pm.me>",
  "license": "MIT",
  "homepage": "https://github.com/ingniius/ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ingniius/ui.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/ingniius/ui/issues"
  },
  "maintainers": [
    "@omaucf <omaucf@pm.me>"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "style": "./dist/index.css",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "style": "./dist/index.css",
      "import": "./dist/index.mjs"
    },
    "./icon": "./dist/icon/index.mjs",
    "./icon/heroicons-outline": "./dist/icon/heroicons-outline.mjs",
    "./icon/heroicons-solid": "./dist/icon/heroicons-solid.mjs",
    "./icon/hugeicons": "./dist/icon/hugeicons.mjs",
    "./icon/lucide": "./dist/icon/lucide.mjs",
    "./icon/phosphor": "./dist/icon/phosphor.mjs",
    "./icon/tabler": "./dist/icon/tabler.mjs",
    "./integration/app-config": "./dist/integration/app-config.mjs",
    "./constants": "./dist/lib/constants/index.mjs",
    "./helpers": "./dist/lib/helpers/index.mjs",
    "./helpers/generate": "./dist/lib/helpers/generate.mjs",
    "./helpers/resolve": "./dist/lib/helpers/resolve.mjs",
    "./helpers/template": "./dist/lib/helpers/template.mjs",
    "./types": "./dist/lib/types/index.mjs",
    "./types/abstract": "./dist/lib/types/abstract.mjs",
    "./types/color": "./dist/lib/types/color.mjs",
    "./types/component": "./dist/lib/types/component.mjs",
    "./types/icon": "./dist/lib/types/icon.mjs",
    "./types/theme": "./dist/lib/types/theme.mjs",
    "./utils": "./dist/lib/utils/index.mjs",
    "./utils/tailwind": "./dist/lib/utils/tailwind.mjs",
    "./utils/toolkit": "./dist/lib/utils/toolkit.mjs",
    "./theme": "./dist/theme/index.mjs",
    "./theme/avatar": "./dist/theme/avatar.mjs",
    "./theme/button": "./dist/theme/button.mjs",
    "./theme/card": "./dist/theme/card.mjs",
    "./theme/container": "./dist/theme/container.mjs",
    "./theme/link": "./dist/theme/link.mjs",
    "./theme/main": "./dist/theme/main.mjs",
    "./unplugin": "./dist/unplugin.mjs",
    "./vite": "./dist/vite.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist/**/*.css",
    "dist/**/*.d.mts",
    "dist/**/*.mjs",
    "package.json"
  ],
  "scripts": {
    "prepare": "[ ! -d dist ] && run-s build || true",
    "build": "tsdown",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "git clean -xdf .cache .turbo dist coverage node_modules"
  },
  "peerDependencies": {
    "@tailwindcss/vite": ">=4",
    "defu": ">=6",
    "es-toolkit": ">=1.43",
    "tailwindcss": ">=4",
    "tailwind-variants": ">=3",
    "unplugin": ">=2.3",
    "vite": ">=7"
  },
  "peerDependenciesMeta": {
    "@tailwindcss/vite": {
      "optional": true
    },
    "defu": {
      "optional": true
    },
    "es-toolkit": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    },
    "tailwind-variants": {
      "optional": true
    },
    "unplugin": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "tailwind-merge": "^3.4.0"
  }
}
