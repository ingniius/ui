{
  "name": "@veehance/core",
  "version": "0.0.0",
  "type": "module",
  "author": "@ingniius <ingniius@pm.me>",
  "license": "MIT",
  "homepage": "https://github.com/ingniius/ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ingniius/ui.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/ingniius/ui/issues"
  },
  "maintainers": [
    "@omaucf <omaucf@pm.me>"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "style": "./dist/index.css",
      "import": "./dist/index.js"
    },
    "./icon": "./dist/icon/index.js",
    "./icon/heroicons-outline": "./dist/icon/heroicons-outline.js",
    "./icon/heroicons-solid": "./dist/icon/heroicons-solid.js",
    "./icon/hugeicons": "./dist/icon/hugeicons.js",
    "./icon/lucide": "./dist/icon/lucide.js",
    "./icon/phosphor": "./dist/icon/phosphor.js",
    "./icon/tabler": "./dist/icon/tabler.js",
    "./constants": "./dist/lib/constants/index.js",
    "./constants/core": "./dist/lib/constants/core.js",
    "./constants/react": "./dist/lib/constants/react.js",
    "./constants/vue": "./dist/lib/constants/vue.js",
    "./helpers": "./dist/lib/helpers/index.js",
    "./helpers/generate": "./dist/lib/helpers/generate.js",
    "./helpers/iconset": "./dist/lib/helpers/iconset.js",
    "./helpers/resolve": "./dist/lib/helpers/resolve.js",
    "./helpers/template": "./dist/lib/helpers/template.js",
    "./types": "./dist/lib/types/index.js",
    "./types/abstract": "./dist/lib/types/abstract.js",
    "./types/color": "./dist/lib/types/color.js",
    "./types/component": "./dist/lib/types/component.js",
    "./types/icon": "./dist/lib/types/icon.js",
    "./types/theme": "./dist/lib/types/theme.js",
    "./utils": "./dist/lib/utils/index.js",
    "./utils/tailwind": "./dist/lib/utils/tailwind.js",
    "./utils/toolkit": "./dist/lib/utils/toolkit.js",
    "./theme": "./dist/theme/index.js",
    "./theme/ui": "./dist/theme/ui/index.js",
    "./theme/ui/container": "./dist/theme/ui/container.js",
    "./theme/ui/link": "./dist/theme/ui/link.js",
    "./theme/ui/main": "./dist/theme/ui/main.js",
    "./package.json": "./package.json"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist/**/*.css",
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "package.json"
  ],
  "scripts": {
    "prepare": "[ ! -d dist ] && run-s build || true",
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "git clean -xdf .cache .turbo coverage dist node_modules"
  },
  "peerDependencies": {
    "defu": ">=6",
    "es-toolkit": ">=1.43",
    "ohash": ">=2",
    "tailwindcss": ">=4",
    "tailwind-variants": ">=3"
  },
  "peerDependenciesMeta": {
    "defu": {
      "optional": true
    },
    "es-toolkit": {
      "optional": true
    },
    "ohash": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    },
    "tailwind-variants": {
      "optional": true
    }
  },
  "dependencies": {
    "tailwind-merge": "^3.4.0"
  }
}
