{
  "name": "@example/nuxt",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "[ ! -d .nuxt ] && nuxt prepare || true",
    "start": "node .output/server/index.mjs",
    "dev": "dotenv-run -- nuxt dev",
    "build": "nuxt build",
    "typecheck": "nuxt typecheck --noEmit",
    "clean": "git clean -xdf .cache .nuxt .output .turbo node_modules"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.87",
    "@nuxt/fonts": "^0.13.0",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@veehance/core": "workspace:*",
    "@veehance/vue": "workspace:*",
    "@vueuse/core": "^14.1.0",
    "defu": "^6.1.4",
    "es-toolkit": "^1.44.0",
    "reka-ui": "^2.7.0",
    "scule": "^1.3.0",
    "tailwind-variants": "^3.2.2",
    "vue": "catalog:",
    "zod": "^4.3.6"
  }
}
