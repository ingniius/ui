{
  "name": "@example/nuxt",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "[ ! -d .nuxt ] && nuxt prepare || true",
    "start": "node .output/server/index.mjs",
    "dev": "dotenv-run -- nuxt dev",
    "build": "nuxt build",
    "typecheck": "nuxt typecheck --noEmit",
    "clean": "git clean -xdf .cache .nuxt .output .turbo node_modules"
  },
  "dependencies": {
    "@iconify/utils": "^3.1.0",
    "@iconify/vue": "^5.0.0",
    "@iconify-json/lucide": "^1.2.90",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@veehance/core": "workspace:*",
    "@veehance/vue": "workspace:*",
    "@vueuse/core": "^14.2.1",
    "defu": "^6.1.4",
    "radash": "^12.1.1",
    "reka-ui": "^2.8.0",
    "scule": "^1.3.0",
    "tailwind-variants": "^3.2.2",
    "vue": "catalog:",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "vite": "catalog:"
  }
}
