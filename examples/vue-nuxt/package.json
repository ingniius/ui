{
  "name": "@example/vue-nuxt",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "[ ! -d .nuxt ] && nuxt prepare || true",
    "start": "node .output/server/index.mjs",
    "dev": "dotenv-run -- nuxt dev",
    "build": "nuxt build",
    "typecheck": "nuxt typecheck --noEmit",
    "clean": "git clean -xdf .cache .nuxt .output .turbo node_modules"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.82",
    "@veehance/core": "workspace:*",
    "@veehance/vue": "workspace:*",
    "es-toolkit": "1.43.0",
    "vue": "catalog:",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.1.1",
    "nuxt": "^4.2.2"
  }
}
