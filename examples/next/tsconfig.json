{
  "extends": "@veehance/typescript/react.json",
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": { "#build/*": ["./generated/*"], "@/*": ["./src/*"] },
    "plugins": [{ "name": "next" }],
    "target": "ES2017"
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
