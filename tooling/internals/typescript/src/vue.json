{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Vue.js",
  "extends": "./base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "lib": ["dom", "dom.iterable", "esnext"],
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true
  }
}
