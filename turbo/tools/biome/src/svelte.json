{
  "$schema": "../node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/svelte"],
  "overrides": [
    {
      "includes": ["**/*.svelte"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "off",
            "noUnusedImports": "off"
          },
          "style": {
            "useConst": "off",
            "useImportType": "off"
          },
          "suspicious": {
            "noReactSpecificProps": "error"
          }
        }
      }
    }
  ]
}
