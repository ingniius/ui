{
    "arrowParens": "always",
    "overrides": [{ "files": ["*.blade.php"], "options": { "parser": "blade" } }],
    "printWidth": 120,
    "proseWrap": "always",
    "plugins": ["prettier-plugin-blade", "prettier-plugin-tailwindcss"],
    "quoteProps": "consistent",
    "semi": true,
    "singleQuote": true,
    "tabWidth": 4,
    "trailingComma": "es5",
    "useTabs": false
}
