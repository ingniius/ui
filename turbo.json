{
  "$schema": "https://turborepo.org/schema.json",
  "pipeline": {
    "start": {
      "persistent": true,
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".nuxt/**", ".output/**", ".vercel/output/**", "dist/**"]
    },
    "format": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
